  <PLMWFTIL_FilteredTiles>Tuiles Filtrées</PLMWFTIL_FilteredTiles>

    <!-- buttons for navigating in the list of filtered tiles (most strings are tool-tips); note that these strings are
    also used on the Prepare Landing "minimized window".    
    -->
    <!-- EN: Go to the start of the tile list. -->
  <PLMWFTIL_GoToStartOfTileList>Aller au début de la liste des tuiles.</PLMWFTIL_GoToStartOfTileList>
    <!-- EN: Reached start of the tile list. -->
  <PLMWFTIL_ReachedListStart>Début de la liste des tuiles atteint.</PLMWFTIL_ReachedListStart> <!-- info message; string is followed by a number -->
