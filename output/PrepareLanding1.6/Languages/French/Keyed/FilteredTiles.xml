  <PLMWFTIL_GoToNextListPage>Aller à la page suivante de la liste.</PLMWFTIL_GoToNextListPage>
    <!-- EN: Go to the end of the tile list. -->
  <PLMWFTIL_GoToEndOfList>Aller à la fin de la liste des tuiles.</PLMWFTIL_GoToEndOfList>


