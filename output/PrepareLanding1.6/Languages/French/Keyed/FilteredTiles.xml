  <PLMWFTIL_ClearFilteredTiles>Effacer la liste des tuiles filtrées</PLMWFTIL_ClearFilteredTiles>
    <!-- EN: Selected Tile Information -->
  <PLMWFTIL_SelectedTileInfo>Information de la tuile sélectionnée</PLMWFTIL_SelectedTileInfo>
