<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
    <!-- Use 4 spaces indentation, NOT tabs -->
    <!-- Overall prefix for the mod is "PL" for PrepareLanding; "MW" for Main Window -->

    <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Terrain Tab [TT] ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
    <!-- EN: Terrain -->
  <PLMWTT_TabName>Terrain</PLMWTT_TabName>

    <!-- EN: Reset all elements to their default (Partial) state. -->
  <PLMWTT_ButtonResetTooltip>Réinitialiser tous les éléments à leur état par défaut (partiel).</PLMWTT_ButtonResetTooltip>
    <!-- EN: Set all elements to the On state. -->
  <PLMWTT_ButtonAllTooltip>Définir tous les éléments à l'état Activé.</PLMWTT_ButtonAllTooltip>
    <!-- EN: Set all elements to the Off state. -->
  <PLMWTT_ButtonNoneTooltip>Définir tous les éléments à l'état Désactivé.</PLMWTT_ButtonNoneTooltip>

    <!-- EN: Biome Types -->
  <PLMWTT_BiomeTypes>Types de Biomes</PLMWTT_BiomeTypes>
    <!-- EN: Select Biome -->
  <PLMWTT_SelectBiome>Sélectionner un Biome</PLMWTT_SelectBiome>
    <!-- EN: Select Biome Type -->
  <PLMWTT_SelectBiomeType>Sélectionner un type de Biome</PLMWTT_SelectBiomeType>
    <!-- EN: Any Biome -->
  <PLMWTT_AnyBiome>N'importe quel Biome</PLMWTT_AnyBiome>

    <!-- EN: Coastal Tiles -->
  <PLMWTT_CoastalTiles>Tuiles côtières</PLMWTT_CoastalTiles>
    <!-- EN: Is Coastal Tile (ocean) -->
  <PLMWTT_IsCoastalTileOcean>Tuile côtière (océan)</PLMWTT_IsCoastalTileOcean>
    <!-- EN: Use Coastal Rotation -->
  <PLMWTT_UseCoastalRoation>Utiliser rotation côtière</PLMWTT_UseCoastalRoation>
    <!-- EN: Allow to search for coastal ocean/sea tiles which have a coast facing a specific direction. -->
  <PLMWTT_UseCoastalRoationTooltip>Permet de rechercher des tuiles côtières (océan / mer) ayant une côte faisant face à une direction spécifique.</PLMWTT_UseCoastalRoationTooltip>
    <!-- EN: Select Coast Rotation -->
  <PLMWTT_SelectCoastRotation>Sélectionner Rotation côtière</PLMWTT_SelectCoastRotation>
    <!-- EN: Selected Coast Rotation -->
  <PLMWTT_SelectedCoastRotation>Rotation côtière sélectionnée</PLMWTT_SelectedCoastRotation>
    <!-- EN: Is Coastal Tile (lake) -->
  <PLMWTT_IsCoastalTileLake>Tuile côtière (lac)</PLMWTT_IsCoastalTileLake>
    <!-- EN: A lake is at most 15 tiles of water surrounded by land. -->
  <PLMWTT_IsCoastalTileLakeTooltip>Un lac se compose d'au plus 15 tuiles d'eau entourées par de la terre.</PLMWTT_IsCoastalTileLakeTooltip>

    <!-- EN: Terrain Types -->
  <PLMWTT_TerrainTypes>Types de Terrains</PLMWTT_TerrainTypes>
    <!-- EN: Select Terrain -->
  <PLMWTT_SelectTerrain>Sélectionner un Terrain</PLMWTT_SelectTerrain>

    <!-- EN: River Types -->
  <PLMWTT_RiverTypes>Types de Rivières</PLMWTT_RiverTypes>

    <!-- EN: OR -->
  <PLMWTT_FilterBooleanOr>OU</PLMWTT_FilterBooleanOr>  <!-- boolean OR; uppercase -->
    <!-- EN: AND -->
  <PLMWTT_FilterBooleanAnd>ET</PLMWTT_FilterBooleanAnd>  <!-- boolean AND; uppercase -->
    <!-- EN: Type of filtering to apply.
OR: each item is evaluated independently.
AND: all items are evaluated together. -->
  <PLMWTT_ORANDTooltip>Type de filtrage à appliquer.\nOU: chaque élément est évalué indépendamment.\nET: tous les éléments sont évalués ensembles.</PLMWTT_ORANDTooltip>
    <!-- EN: If True, Off and Partial states do not allow any tile selection.
If false, they allow selection of tiles. -->
  <PLMWTT_OffPartialTooltip>Si Activé : les états Désactivé et Partiel ne permettent pas la sélection de tuiles.\nSi Désactivé : ils permettent la sélection de tuiles.</PLMWTT_OffPartialTooltip>
    <!-- EN: Sel. -->
  <PLMWTT_SelectedShort>Sel.</PLMWTT_SelectedShort> <!-- 'Sel.' as in "Selected" -->

    <!-- EN: Road Types -->
  <PLMWTT_RoadTypes>Types de Routes</PLMWTT_RoadTypes>

    <!-- EN: Stone Types -->
  <PLMWTT_StoneTypes>Types de Pierres</PLMWTT_StoneTypes>
    <!-- EN:  Whether Stone Filtering is order dependent or not.\nPress button to change filter state. -->
  <PLMWTT_StoneOrderTooltip>Indique si le filtrage des pierres dépend de l'ordre ou non.\nAppuyez sur le bouton pour changer l'état du filtre.</PLMWTT_StoneOrderTooltip>
    <!-- EN: Ordered -->
  <PLMWTT_Ordered>Ordonné</PLMWTT_Ordered> <!-- as of now only used for stone filter -->
    <!-- EN: No Order -->
  <PLMWTT_NoOrder>Non Ordonné</PLMWTT_NoOrder> <!-- as of now only used for stone filter -->
    <!-- EN: Filter -->
  <PLMWTT_Filter>Filtrage</PLMWTT_Filter> <!-- as in "Filter: Ordered" or "Filter: No order" -->
    <!-- EN: Use # of stone types [2,3] -->
  <PLMWTT_UseNumberOfStoneTypes>Utiliser un nombre de pierres précis [2,3]</PLMWTT_UseNumberOfStoneTypes>
    <!-- EN: Filter tiles that have only the given number of stone types (whatever the types are). This disables the other stone filters. -->
  <PLMWTT_UseNumberOfStoneTypesToolTip>Filtre les tuiles ayant le bon nombre de pierres (quel que soit leur type). Cela désactive les autres filtres.</PLMWTT_UseNumberOfStoneTypesToolTip>

</LanguageData>